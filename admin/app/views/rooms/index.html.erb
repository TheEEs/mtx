<% content_for :title, t("activerecord.models.room") %>
<div class="w-full space-y-8">
  <% if notice.present? %>
    <div role="alert" class="alert alert-success shadow-sm mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <span><%= notice %></span>
    </div>
  <% end %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h1 class="font-bold text-4xl"><%= t("activerecord.models.room") %></h1>
      <p class="text-base-content/60 mt-1 italic">Danh sách các kênh phát sóng trực tuyến đang hoạt động.</p>
    </div>
    <%= link_to new_room_path, class: "btn btn-primary rounded-lg" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      <%= t("actions.new", model: Room.model_name.human) %>
    <% end %>
  </div>
  <div class="bg-base-100 rounded-xl shadow-xl overflow-hidden border border-base-300">
    <div class="overflow-x-auto">
      <table class="table table-zebra w-full">
        <thead>
          <tr class="bg-base-200/50">
            <th class="text-sm font-semibold uppercase"><%= Room.human_attribute_name(:name) %></th>
            <th class="hidden md:table-cell text-sm font-semibold uppercase"><%= Room.human_attribute_name(:owner) %></th>
            <th class="hidden lg:table-cell text-sm font-semibold uppercase"><%= Room.human_attribute_name(:valid_from) %></th>
            <th class="hidden lg:table-cell text-sm font-semibold uppercase"><%= Room.human_attribute_name(:valid_to) %></th>
            <th class="text-right text-sm font-semibold uppercase">Thao tác</th>
          </tr>
        </thead>
        <tbody id="rooms">
          <% if @rooms.any? %>
            <%= render @rooms %>
          <% else %>
            <tr>
              <td colspan="4" class="text-center py-20">
                <div class="flex flex-col items-center gap-3 opacity-30">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" /></svg>
                  <p class="font-medium text-xl">Chưa có kênh nào được tạo.</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
